{
  "name": "auraflow-frontend",
  "version": "0.1.0",
  "private": true,
  "main": "public/electron.js",
  "homepage": "./",
  "description": "AuraFlow AI - Universal Strategic Engine",
  "author": "AuraFlow Team",
  "dependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "autoprefixer": "^10.4.27",
    "axios": "^1.13.6",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-scripts": "5.0.1",
    "tailwindcss": "^4.2.2",
    "wait-on": "^9.0.4",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "electron": "electron .",
    "dev": "concurrently \"npm start\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "package": "npm run build && npx electron-builder build --win"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "build": {
    "appId": "com.auraflow.ai",
    "productName": "AuraFlow AI",
    "files": [
      "build/**/*",
      "public/electron.js"
    ],
    "extraResources": [
      {
        "from": "../auraflow-backend/dist/auraflow-backend.exe",
        "to": "backend/auraflow-backend.exe"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/logo512.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  }
}